@model mvc.starter.template.Web.ViewModels.UsuarioFormViewModel

@{
    ViewData["Title"] = Model.Id == 0
        ? "New User"
        : "Edit User";
}

@await Html.PartialAsync("_IndexSubheader", (IndexSubheaderViewModel)ViewBag.Subheader)
@await Html.PartialAsync("_IndexAlerts")

<form asp-action="Form" method="post" class="mt-4">

    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="col-md-6 d-flex align-items-end mt-2">
        <form-switch asp-for="Status" />
    </div>

    <div class="form-section">

        <h5 class="section-title">
            Personal Information
        </h5>

        <div class="row g-3 mt-1">

            <div class="col-md-6">
                <form-input asp-for="Name" />
            </div>

            <div class="col-md-6">
                <form-input asp-for="LastName" />
            </div>

            <div class="col-md-6">
                <form-input asp-for="Email" type="email" />
            </div>

            <div class="col-md-6">
                <form-input asp-for="Telephone" mask="(00) 00000-0000" placeholder="(00) 00000-0000" />
            </div>

            <div class="col-md-6">
                <form-input asp-for="DtBirth" mask="00/00/0000" placeholder="00/00/0000" />
            </div>

        </div>

    </div>

    <hr class="section-divider" />

    <div class="form-section">

        <h5 class="section-title">
            Credential
        </h5>

        <div class="row g-3 mt-1">

            <div class="col-md-6">
                <form-input asp-for="Login" />
            </div>

            <div class="col-md-6"></div>

            <div class="col-md-6">

                <div class="input-group">
                    <input asp-for="Password"
                           class="form-control"
                           type="password"
                           id="Password" />

                    <button type="button"
                            class="btn btn-outline-secondary"
                            onclick="togglePassword('Password', this)">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
            </div>

            <div class="col-md-6">

                <div class="input-group">
                    <input asp-for="PasswordConfirmation"
                           class="form-control"
                           type="password"
                           id="PasswordConfirmation" />

                    <button type="button"
                            class="btn btn-outline-secondary"
                            onclick="togglePassword('PasswordConfirmation', this)">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
            </div>

            @if (Model.Id > 0)
            {
                <div class="col-12">
                    <small class="text-muted">
                        Leave password fields empty to keep current password.
                    </small>
                </div>
            }

        </div>

    </div>

    <hr class="section-divider" />

    <div class="form-section">

        <h5 class="section-title">
            Access Settings
        </h5>

        <div class="row g-3 mt-1">

            <div class="col-md-6">
                <label asp-for="RoleId" class="form-label fw-bold"></label>

                <select asp-for="RoleId" class="form-select">
                    <option value="">Select a role</option>

                    @foreach (var perfil in Model.Roles)
                    {
                        <option value="@perfil.Id">
                            @perfil.Name
                        </option>
                    }
                </select>

                <span asp-validation-for="RoleId"
                      class="text-danger small"></span>
            </div>
        </div>     
    </div>

    <div class="mt-4 d-flex justify-content-start gap-2">

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            Back
        </a>

        <button type="submit"
                class="btn btn-primary px-4">
            <i class="bi bi-check-lg me-1"></i>
            Save
        </button>
    </div>
</form>

@section Scripts {
    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const icon = button.querySelector('i');

            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}
