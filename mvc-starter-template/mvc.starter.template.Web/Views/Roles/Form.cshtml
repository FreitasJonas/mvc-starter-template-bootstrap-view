@model mvc.starter.template.Web.ViewModels.RoleFormViewModel
@using mvc.starter.template.Web.ViewModels

@{
	ViewData["Title"] = Model.Id == 0
		? "New Role"
		: "Edit Role";
}

@section styles {
	<link href="~/css/app.permission-tree.css" rel="stylesheet" />
}

@await Html.PartialAsync("_IndexSubheader",
				(IndexSubheaderViewModel)ViewBag.Subheader)

@await Html.PartialAsync("_IndexAlerts")

<form asp-action="@(Model.Id == 0 ? "Create" : "Edit")"
	  method="post">

	@Html.AntiForgeryToken()
	<input type="hidden" asp-for="Id" />

	<div class="row g-4">

		<div class="col-12 col-md-6">
			<form-input asp-for="Name" />
		</div>

		<div class="col-12 col-md-6">
			<form-input asp-for="Description" />
		</div>

		<div class="col-12">
			<hr class="my-4" />

			<h5 class="mb-3">
				<i class="fal fa-key me-1"></i>
				Permissions
			</h5>

			<div class="permission-tree">
				@foreach (var node in Model.PermissionTree)
				{
					@Html.Partial("_PermissionNode", node)
				}
			</div>
		</div>

		<div class="mt-4 d-flex justify-content-start gap-2">

			<a asp-action="Index"
			   class="btn btn-outline-secondary">
				Back
			</a>

			<button type="submit"
					class="btn btn-primary px-4">
				<i class="bi bi-check-lg me-1"></i>
				Save
			</button>
		</div>

	</div>
</form>

@section Scripts {
	<script src="~/js/permissions-tree.js"></script>
}
