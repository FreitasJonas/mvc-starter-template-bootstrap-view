@{
    ViewData["Title"] = "Security & Permissions";
    ViewData["Description"] =
        "Security documentation covering authentication, two-factor verification, policy-based permissions and access control implementation.";
}

@await Html.PartialAsync("_IndexAlerts")

<div class="container-fluid">

    <!-- Header -->
    <div class="row mb-5">
        <div class="col-xl-9">

            <span class="badge bg-danger-subtle text-danger mb-2">
                Security
            </span>

            <h1 class="fw-bold mb-3">
                Security & Permissions
            </h1>

            <p class="fs-5 text-muted">
                This section describes how authentication, authorization
                and permission enforcement are implemented in the system.
            </p>

            <div class="alert alert-danger mt-4">
                <i class="bi bi-shield-lock me-2"></i>
                Security is implemented as a structural component
                of the architecture, not as a UI-level feature.
            </div>
        </div>
    </div>

    <!-- Security Model -->
    <div class="row mb-5">
        <div class="col-xl-12">
            <div class="border rounded p-4 bg-light-subtle">
                <h4 class="fw-semibold mb-3">
                    <i class="bi bi-diagram-3 me-2"></i>
                    Security model layers
                </h4>

                <ul class="text-muted mb-0">
                    <li><strong>Authentication</strong> – establishes user identity</li>
                    <li><strong>Authorization</strong> – evaluates permissions</li>
                    <li><strong>Auditing</strong> – records user actions</li>
                </ul>

                <p class="text-muted mt-3 mb-0">
                    Each concern is implemented independently to avoid
                    cross-layer coupling.
                </p>
            </div>
        </div>
    </div>

    <!-- Authentication -->
    <div class="row mb-5">
        <div class="col-xl-12">
            <div class="border rounded p-4">
                <h4 class="fw-semibold mb-3">
                    <i class="bi bi-key me-2"></i>
                    Authentication
                </h4>

                <p class="text-muted mb-3">
                    The system uses <strong>Cookie Authentication</strong>
                    provided by ASP.NET Core.
                </p>

                <ul class="text-muted mb-3">
                    <li>Secure login flow</li>
                    <li>Encrypted authentication cookie</li>
                    <li>Configurable expiration</li>
                    <li>Sliding expiration support</li>
                </ul>

                <div class="alert alert-info mb-0">
                    <i class="bi bi-info-circle me-2"></i>
                    Authentication identifies the user but does not
                    automatically grant feature access.
                </div>
            </div>
        </div>
    </div>

    <!-- Two Factor -->
    <div class="row mb-5">
        <div class="col-xl-12">
            <div class="border rounded p-4 bg-light-subtle">
                <h4 class="fw-semibold mb-3">
                    <i class="bi bi-phone me-2"></i>
                    Two-Factor Verification (2FA)
                </h4>

                <p class="text-muted mb-3">
                    An optional second verification step is available
                    after successful credential validation.
                </p>

                <ul class="text-muted mb-0">
                    <li>Time-limited verification code</li>
                    <li>Separate verification screen</li>
                    <li>Pluggable delivery strategy (email, SMS, etc.)</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Authorization Model -->
    <div class="row mb-5">
        <div class="col-xl-12">
            <div class="border rounded p-4">
                <h4 class="fw-semibold mb-3">
                    <i class="bi bi-person-lock me-2"></i>
                    Authorization model
                </h4>

                <p class="text-muted mb-3">
                    Authorization is implemented using a
                    <strong>policy-based permission model</strong>.
                </p>

                <ul class="text-muted mb-3">
                    <li>Fine-grained permissions</li>
                    <li>Explicit feature-to-permission mapping</li>
                    <li>Role-based grouping of permissions</li>
                </ul>

<pre class="mb-0">
Permission.UsersView
Permission.UsersCreate
Permission.UsersEdit
Permission.UsersDelete
</pre>
            </div>
        </div>
    </div>

    <!-- Permission Flow -->
    <div class="row mb-5">
        <div class="col-xl-12">
            <div class="border rounded p-4 bg-light-subtle">
                <h4 class="fw-semibold mb-3">
                    <i class="bi bi-arrow-repeat me-2"></i>
                    Permission evaluation flow
                </h4>

                <ol class="text-muted mb-0">
                    <li>User authenticates successfully</li>
                    <li>User permissions are loaded as claims</li>
                    <li>Controller declares required permission</li>
                    <li>PermissionHandler evaluates access</li>
                    <li>Access is granted or denied</li>
                </ol>
            </div>
        </div>
    </div>

    <!-- Declarative Enforcement -->
    <div class="row mb-5">
        <div class="col-xl-12">
            <div class="border rounded p-4">
                <h4 class="fw-semibold mb-3">
                    <i class="bi bi-code-slash me-2"></i>
                    Declarative permission enforcement
                </h4>

                <p class="text-muted mb-3">
                    Permissions are enforced declaratively
                    at controller or action level.
                </p>

<pre class="mb-0">
[PermissionAuthorize("Permission.UsersView")]
public IActionResult Index()
{
    return View();
}
</pre>

                <p class="text-muted mt-3 mb-0">
                    This keeps authorization visible,
                    centralized and predictable.
                </p>
            </div>
        </div>
    </div>

    <!-- Access Denied -->
    <div class="row mb-5">
        <div class="col-xl-12">
            <div class="border rounded p-4 bg-light-subtle">
                <h4 class="fw-semibold mb-3">
                    <i class="bi bi-x-circle me-2"></i>
                    Access denied handling
                </h4>

                <ul class="text-muted mb-0">
                    <li>Custom PermissionResultHandler</li>
                    <li>Graceful redirection for UI requests</li>
                    <li>No exposure of internal details</li>
                    <li>Controlled behavior for API scenarios</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Security Infrastructure -->
    <div class="row mb-5">
        <div class="col-xl-12">
            <div class="border rounded p-4">
                <h4 class="fw-semibold mb-3">
                    <i class="bi bi-layers me-2"></i>
                    Security infrastructure components
                </h4>

                <ul class="text-muted mb-0">
                    <li>PermissionAuthorizeAttribute</li>
                    <li>PermissionRequirement</li>
                    <li>PermissionHandler</li>
                    <li>PermissionPolicyProvider</li>
                    <li>PermissionResultHandler</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Benefits -->
    <div class="row">
        <div class="col-xl-12">
            <div class="alert alert-primary d-flex align-items-center">
                <i class="bi bi-check-circle me-3 fs-3"></i>
                <div>
                    <strong>Structured and auditable security model</strong>
                    <div class="small">
                        The system provides predictable permission enforcement,
                        clear access boundaries and scalable security policies
                        suitable for production environments.
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>