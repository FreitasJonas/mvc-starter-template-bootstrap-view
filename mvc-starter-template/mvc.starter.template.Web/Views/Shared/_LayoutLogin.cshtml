<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - MVC Starter</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/app.css" rel="stylesheet" />
    <link href="~/css/app.loader.css" rel="stylesheet" />
    <link href="~/css/app.login.css" rel="stylesheet" />

    @RenderSection("Styles", required: false)
</head>

<body class="login-page">

    <div class="login-wrapper">

        <!-- LEFT PANEL -->
        <div class="login-left">
            <div class="login-left-content">

                <div class="logo mb-4">
                    
                </div>

                <h1 class="login-title">
                    MVC Starter Template
                </h1>

                <p class="login-subtitle">
                    Discover the ideal template for your new project.
                </p>

            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="login-right">
            <div class="login-form-container">
                @RenderBody()
            </div>
        </div>

    </div>

    @Html.Partial("_Loader")

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/app.loader.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
