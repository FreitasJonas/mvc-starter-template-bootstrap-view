@model mvc.starter.template.Web.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

<div class="form-header text-center mb-4">
    <h4 class="fw-bold">Sign in</h4>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<form asp-action="Index" method="post" autocomplete="off">

    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Login" class="form-label fw-bold"></label>
        <input asp-for="Login"
               class="form-control form-control-lg"
               placeholder="Enter your login" />
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label fw-bold"></label>
        <input asp-for="Password"
               type="password"
               class="form-control form-control-lg"
               placeholder="Enter your password" />
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" name="RememberMe">
            <label class="form-check-label small">
                Remember me
            </label>
        </div>

        <a href="#" class="small text-decoration-none">
            Forgot password?
        </a>
    </div>

    <div class="d-flex gap-3">
        <button type="submit" class="btn btn-primary btn-lg flex-fill">
            Login
        </button>

        <a href="#" class="btn btn-outline-primary btn-lg flex-fill">
            Sign up
        </a>
    </div>

</form>

<div class="text-center mt-4 small text-muted">
    Follow
</div>
