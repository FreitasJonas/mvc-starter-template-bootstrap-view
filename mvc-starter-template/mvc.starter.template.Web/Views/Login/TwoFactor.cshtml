@model mvc.starter.template.Web.ViewModels.TwoFactorViewModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

<div class="form-header text-center mb-4">
    <h4 class="fw-bold">Two-Factor Authentication</h4>
    <p class="text-muted small mb-0">
        Enter the verification code sent to your device
    </p>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<form asp-action="TwoFactor" method="post">

    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserId" />

    <div class="mb-4">
        <label asp-for="Code" class="form-label fw-bold"></label>

        <input asp-for="Code"
               class="form-control form-control-lg text-center fw-semibold code-input"
               maxlength="6"
               inputmode="numeric"
               placeholder="000000" />

        <span asp-validation-for="Code"
              class="text-danger d-block mt-1"></span>
    </div>

    <button type="submit"
            class="btn btn-primary btn-lg w-100 mb-3">
        Continue
    </button>

    <div class="text-center small text-muted">
        Didn’t receive the code?
        <a href="#" class="text-decoration-none ms-1">
            Resend
        </a>
    </div>
</form>


@section Scripts {
    <script>
        // DEMO ONLY – remove in production
        document.addEventListener('DOMContentLoaded', function () {

            const code = '@(TempData["DemoCode"] ?? "")';

            if (code) {
                alert('Demo code: ' + code);
            }
        });
    </script>
}
